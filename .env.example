# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
# Transaction mode pooler (port 6543) for serverless (Vercel)
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) for Prisma migrations/push
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Anajak Stock API
ANAJAK_STOCK_API_URL=https://stock.anajak.com/api
ANAJAK_STOCK_API_KEY=your-api-key

# Gemini (preflight ไฟล์งานพิมพ์ DTF — ก้อน 4) · server-only · คีย์จาก aistudio.google.com/apikey
# แนะนำ: จำกัดสิทธิ์คีย์ใน Google Cloud ให้ใช้ได้แค่ Generative Language API
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3.5-flash   # ไม่ตั้ง = ใช้ default นี้

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (/api/cron/overdue) — ตั้งบน Vercel แล้ว Vercel Cron จะแนบ Bearer ให้เอง
# ไม่ตั้ง = route ปฏิเสธทุก request (fail-closed) · local ไม่บังคับ (มี sweep อัตโนมัติจากหน้า billing)
CRON_SECRET=your-random-secret
