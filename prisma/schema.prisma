generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  OWNER
  MANAGER
  ACCOUNTANT
  PRODUCTION_STAFF
  DESIGNER
  SALES
}

enum OrderType {
  READY_MADE
  CUSTOM
}

enum OrderChannel {
  SHOPEE
  LAZADA
  TIKTOK
  LINE
  WALK_IN
  PHONE
  WEBSITE
}

enum CustomerStatus {
  ORDER_RECEIVED
  PREPARING
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
}

enum InternalStatus {
  DRAFT
  INQUIRY
  CONFIRMED
  DESIGNING
  DESIGN_APPROVED
  PRODUCTION_QUEUE
  PRODUCING
  QUALITY_CHECK
  PACKING
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum ProductionStepType {
  // ทำเองในโรงงาน = DTF เท่านั้น (เบสเคาะ 2026-06-12) — เทคนิคอื่น/ตัดเย็บ/ป้ายคอ = outsource
  // เลนต่อเทคนิค + ขั้นไหนเป็น outsource นิยามที่ src/lib/production-steps.ts (STEP_LANE/OUTSOURCE_STEP_TYPES)
  DTF_PRINT // พิมพ์ฟิล์ม DTF (ทำเอง)
  HEAT_PRESS // รีดร้อนติดเสื้อ (ทำเอง)
  DTG_PRETREAT // legacy — สมัยที่เข้าใจว่า DTG ทำเอง (จริง outsource เป็นขั้นเดียว)
  DTG_PRINT // พิมพ์ DTG (outsource)
  CURING // อบสี/อบฟิล์ม (legacy ชุด DTG ทำเอง)
  // งานตัดเย็บ/อื่นๆ
  PATTERN_MAKING
  SCREEN_PRINTING // สกรีน (outsource)
  TAGGING // เย็บป้ายคอ (outsource)
  PACKAGING
  EMBROIDERY // ปัก (outsource)
  SPECIAL_PRINT
  SEWING // ตัดเย็บใหม่ (outsource)
  CUSTOM
  // เพิ่ม 2026-06-12 — สายเตรียมเสื้อ + sublimation แยกจากพิมพ์พิเศษ
  GARMENT_PICK // เบิกเสื้อจากสต๊อค
  GARMENT_RECEIVE // ตรวจรับเสื้อลูกค้าส่งมา (นับ/เช็คสภาพ)
  SUBLIMATION // Sublimation (outsource)
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  FAILED
}

enum DesignApprovalStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum OutsourceStatus {
  DRAFT
  SENT
  IN_PROGRESS
  COMPLETED
  RECEIVED_BACK
  QC_PASSED
  QC_FAILED
}

enum InvoiceType {
  QUOTATION
  DEPOSIT_INVOICE
  FINAL_INVOICE
  RECEIPT
  CREDIT_NOTE
  DEBIT_NOTE
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOIDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomerSegment {
  VIP
  REGULAR
  NEW
  INACTIVE
  WHOLESALE
  RETAIL
}

enum CustomerType {
  INDIVIDUAL  // บุคคลธรรมดา
  CORPORATE   // นิติบุคคล
}

// tax-point (เผื่อใบกำกับภาษี P1): ขายสินค้า = VAT เกิดตอนส่งมอบ · จ้างทำของ = VAT เกิดตอนรับเงินทุกงวดรวมมัดจำ
enum TaxLineType {
  GOODS        // ขายสินค้า (READY_MADE)
  HIRE_OF_WORK // จ้างทำของ (งานสกรีน/ผลิตตามสั่ง)
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String   @id @default(cuid())
  supabaseId    String   @unique @map("supabase_id")
  email         String   @unique
  name          String
  role          Role     @default(SALES)
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  assignedSteps      ProductionStep[]  @relation("AssignedTo")
  auditLogs          AuditLog[]
  approvalRequests   ApprovalRequest[] @relation("Requester")
  approvalDecisions  ApprovalRequest[] @relation("Approver")
  communicationLogs  CommunicationLog[]
  createdOrders      Order[]           @relation("CreatedBy")
  createdQuotations  Quotation[]       @relation("QuotationCreatedBy")
  costEntries        CostEntry[]       @relation("CostCreatedBy")
  uploadedAttachments Attachment[]     @relation("UploadedBy")
  notifications      Notification[]
  goodsReceipts      GoodsReceipt[]    @relation("GoodsReceivedBy")
  qcRecords          QcRecord[]        @relation("QcCheckedBy")
  printRuns          PrintRun[]        @relation("PrintRunCreatedBy")
  agentApiKeys       AgentApiKey[]     @relation("AgentApiKeyUser")

  @@map("users")
}

// ============================================================
// AI AGENT / MCP (FLOW-REDESIGN ก้อน 5 — MCP เฟสแรก read-only)
// กุญแจต่อ agent ผูก User จริง → ได้ Role เดิม + ผ่าน FK ของ audit/createdBy ·
// เก็บเป็น hash (sha256) ไม่ใช่ plaintext (ยกระดับจาก stock_api_key ใน settings) ·
// ทุกการเรียกลง AgentCallLog (audit ทุก call ตาม ROADMAP)
// ============================================================

model AgentApiKey {
  id          String    @id @default(cuid())
  name        String    // ชื่อ agent เช่น "Nami (เบส)"
  keyHash     String    @unique @map("key_hash") // sha256(raw key) hex — ไม่เก็บ plaintext
  keyPrefix   String    @map("key_prefix") // ส่วนหน้าของ key (เช่น "ana_a1b2c3d4") โชว์ระบุใบได้โดยไม่รั่วทั้ง key
  userId      String    @map("user_id") // ผูก User จริง → role + FK audit/createdBy
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at") // null = ไม่หมดอายุ
  createdById String?   @map("created_by_id") // ใครสร้าง key นี้ (ไม่ทำ FK — แค่บันทึก)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user  User           @relation("AgentApiKeyUser", fields: [userId], references: [id])
  calls AgentCallLog[]

  @@index([userId])
  @@map("agent_api_keys")
}

model AgentCallLog {
  id         String   @id @default(cuid())
  keyId      String   @map("key_id")
  tool       String   // ชื่อ tool ที่เรียก (เช่น "order_status")
  ok         Boolean  // สำเร็จไหม
  errorCode  String?  @map("error_code") // FORBIDDEN / NOT_FOUND / INTERNAL ฯลฯ
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  key AgentApiKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId, createdAt])
  @@index([createdAt])
  @@map("agent_call_logs")
}

// ============================================================
// CUSTOMERS & CRM
// ============================================================

model Customer {
  id              String          @id @default(cuid())
  name            String
  company         String?
  email           String?
  phone           String?
  lineId          String?         @map("line_id")
  address         String?
  taxId           String?         @map("tax_id")
  customerType    CustomerType    @default(INDIVIDUAL) @map("customer_type")
  branchNumber    String?         @map("branch_number") // "00000" = สำนักงานใหญ่
  segment         CustomerSegment @default(NEW)
  rfmScore        Float?          @map("rfm_score") // ยังไม่มีโค้ดใช้ — รอ CRM เต็ม P3
  notes           String?
  tags            String[]        @default([])
  totalOrders     Int             @default(0) @map("total_orders")
  totalSpent      Decimal         @default(0) @map("total_spent") @db.Decimal(12, 2)
  lastOrderAt     DateTime?       @map("last_order_at")

  // Billing address (separate from general address)
  billingAddress      String?     @map("billing_address")
  billingSubDistrict  String?     @map("billing_sub_district")
  billingDistrict     String?     @map("billing_district")
  billingProvince     String?     @map("billing_province")
  billingPostalCode   String?     @map("billing_postal_code")

  // Credit management
  creditLimit         Decimal?    @map("credit_limit") @db.Decimal(12, 2)
  defaultPaymentTerms String?     @map("default_payment_terms") // NET_30, COD, DEPOSIT_50, FULL_PREPAY

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  orders            Order[]
  brandProfiles     BrandProfile[]
  communicationLogs CommunicationLog[]
  invoices          Invoice[]
  quotations        Quotation[]
  billingNotes      BillingNote[]
  filmStocks        FilmStock[]
  whtCertificates   WhtCertificate[]
  artworks          CustomerArtwork[]

  @@map("customers")
}

// ============================================================
// คลังลายต่อลูกค้า (FLOW-REDESIGN ก้อน 4 ชิ้น 2) — "ลาย" เป็นสมบัติของลูกค้า
// เกิดอัตโนมัติเมื่องาน QC ผ่านครบ (ครอบทุก printType รวม outsource — dedupe ด้วย imageUrl
// ซึ่งเป็น proxy URL เสถียร · duplicate ออเดอร์แชร์ URL เดิมจึงชนลายเดิมพอดี) + เพิ่ม/แก้มือได้
// ห้ามมีช่องเงิน (มติ 2026-06-12 เลิก job costing) — ราคาท่าพิมพ์อยู่ ServiceCatalog ที่เดียว
// ============================================================
model CustomerArtwork {
  id            String  @id @default(cuid())
  customerId    String  @map("customer_id")
  name          String // ชื่อลาย เช่น "โลโก้อกซ้าย ดำ" (auto ตอน promote · แก้ทีหลังได้)
  imageUrl      String? @map("image_url") // รูปลาย (ชั้น mockup — โชว์ลูกค้า/portal ได้)
  printFileUrl  String? @map("print_file_url") // ไฟล์พิมพ์จริง (ชั้น 3 — ภายในเท่านั้น ห้ามหลุด portal)
  position      String?
  printType     String? @map("print_type")
  printSize     String? @map("print_size")
  widthCm       Float?  @map("width_cm")
  heightCm      Float?  @map("height_cm")
  colorCount    Int?    @map("color_count")
  // สเปกรีด — กรอกครั้งเดียวที่ลาย (ไม่บังคับ — gap badge ใน UI · ห้ามเป็นช่องบังคับหน้างาน)
  heatTempC     Int?    @map("heat_temp_c")
  heatPressSec  Int?    @map("heat_press_sec")
  heatPressure  String? @map("heat_pressure") // เบา/กลาง/หนัก — free text ตามภาษาช่าง
  specNotes     String? @map("spec_notes")
  sourceOrderId String? @map("source_order_id") // ออเดอร์แรกที่ลายนี้พิมพ์ผ่าน
  isActive      Boolean @default(true) @map("is_active") // เลิกใช้ = ปิด ไม่ลบ (มีออเดอร์เก่าอ้างอยู่)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customer    Customer @relation(fields: [customerId], references: [id])
  sourceOrder Order?   @relation("ArtworkSourceOrder", fields: [sourceOrderId], references: [id])
  prints      OrderItemPrint[]
  filmStocks  FilmStock[]

  // กันลายซ้ำตอน promote พร้อมกันสองออเดอร์ (imageUrl null ได้หลายแถว — ลายเพิ่มมือไม่มีรูป)
  @@unique([customerId, imageUrl])
  @@index([customerId])
  @@map("customer_artworks")
}

// ยังไม่มี UI จัดการ — คง schema ไว้รอ CRM เต็ม P3
model BrandProfile {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  brandName   String   @map("brand_name")
  logoUrl     String?  @map("logo_url")
  colorCodes  String[] @default([]) @map("color_codes")
  fonts       String[] @default([])
  styleNotes  String?  @map("style_notes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("brand_profiles")
}

model CommunicationLog {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  userId     String   @map("user_id")
  channel    String   // LINE, PHONE, EMAIL, IN_PERSON
  subject    String?
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("communication_logs")
}

// ============================================================
// ORDERS (Redesigned)
// ============================================================

model Order {
  id               String         @id @default(cuid())
  orderNumber      String         @unique @map("order_number")
  orderType        OrderType      @default(CUSTOM) @map("order_type")
  channel          OrderChannel   @default(LINE)
  customerId       String         @map("customer_id")
  brandProfileId   String?        @map("brand_profile_id")
  createdById      String         @map("created_by_id")
  customerStatus   CustomerStatus @default(ORDER_RECEIVED) @map("customer_status")
  internalStatus   InternalStatus @default(INQUIRY) @map("internal_status")
  title            String
  description      String?
  deadline         DateTime?

  // Pricing — เงิน = Decimal(12,2) เท่านั้น · taxRate เป็น % (5,2) · profitMargin เป็น % derived คง Float
  subtotalItems    Decimal        @default(0) @map("subtotal_items") @db.Decimal(12, 2)
  subtotalFees     Decimal        @default(0) @map("subtotal_fees") @db.Decimal(12, 2)
  discount         Decimal        @default(0) @db.Decimal(12, 2)
  discountReason   String?        @map("discount_reason")
  taxRate          Decimal        @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount        Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount      Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)

  // Cost tracking
  totalCost        Decimal        @default(0) @map("total_cost") @db.Decimal(12, 2)
  profitMargin     Float?         @map("profit_margin")

  // Business rules
  priority         String         @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  paymentTerms     String?        @map("payment_terms") // NET_30, COD, DEPOSIT_50, FULL_PREPAY
  poNumber         String?        @map("po_number") // Customer's purchase order number
  estimatedQuantity Int?          @map("estimated_quantity") // For INQUIRY stage when exact breakdown is unknown

  // Shipping address (optional, can be set at order creation)
  shippingRecipientName String?   @map("shipping_recipient_name")
  shippingPhone    String?        @map("shipping_phone")
  shippingAddress  String?        @map("shipping_address")
  shippingSubDistrict String?     @map("shipping_sub_district")
  shippingDistrict String?        @map("shipping_district")
  shippingProvince String?        @map("shipping_province")
  shippingPostalCode String?      @map("shipping_postal_code")

  // Marketplace fields (Shopee, Lazada, TikTok)
  externalOrderId  String?        @map("external_order_id")
  platformFee      Decimal?       @map("platform_fee") @db.Decimal(12, 2)
  trackingNumber   String?        @map("tracking_number")

  // เชื่อมจองสต๊อค Anajak Stock (FLOW-REDESIGN ก้อน 1 2026-06-12) — ยืนยันออเดอร์แล้ว
  // จองเสื้อรายไซส์-สีฝั่ง Stock (orderRef = orderNumber) · error เก็บข้อความล่าสุดไว้โชว์/ตามแก้
  stockReservedAt       DateTime? @map("stock_reserved_at")
  stockReservationError String?   @map("stock_reservation_error")
  // เตือนล่วงหน้าก่อนปลดจองค้าง (auto-release) ไปแล้วเมื่อไหร่ — กันเตือนซ้ำทุกวัน · ปลด/จองใหม่ = ล้างกลับ null
  reservationExpiryWarnedAt DateTime? @map("reservation_expiry_warned_at")

  // Blind ship (FLOW-REDESIGN ก้อน 3) — ลูกค้า reseller/แบรนด์: เอกสารในกล่องใช้ชื่อ
  // แบรนด์ลูกค้าเป็นผู้ส่ง ห้ามมีเอกสาร/ชื่อ Anajak (พลาดครั้งเดียวเสียลูกค้าขายซ้ำทั้งราย)
  blindShip           Boolean @default(false) @map("blind_ship")
  blindShipSenderName String? @map("blind_ship_sender_name") // ชื่อผู้ส่งบนใบ (แบรนด์ลูกค้า)

  // ลิงก์อัปโหลดไฟล์ลูกค้า (FLOW-REDESIGN ก้อน 4 ชิ้น 3) — ลูกค้าเปิดผ่าน token ไม่ต้อง login
  // ส่งใน LINE → อัปไฟล์ดิบเข้าออเดอร์ตรง (signed upload URL · เลียน pattern ลิงก์อนุมัติแบบ)
  uploadToken          String?   @unique @map("upload_token")
  uploadTokenExpiresAt DateTime? @map("upload_token_expires_at")

  // ลิงก์สถานะออเดอร์ (FLOW-REDESIGN ก้อน 4 — portal ขั้น 1) — ลูกค้าเปิดดูสถานะ/แบบ/เอกสาร/พัสดุ
  // ผ่าน token ไม่ต้อง login (read-only · โชว์เฉพาะข้อมูลของลูกค้า ห้ามรั่วข้อมูลภายใน)
  statusToken          String?   @unique @map("status_token")
  statusTokenExpiresAt DateTime? @map("status_token_expires_at")

  // Meta
  notes            String?
  cancelledAt      DateTime?      @map("cancelled_at")
  cancelledReason  String?        @map("cancelled_reason")
  completedAt      DateTime?      @map("completed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  customer     Customer       @relation(fields: [customerId], references: [id])
  brandProfile BrandProfile?  @relation(fields: [brandProfileId], references: [id])
  createdBy    User           @relation("CreatedBy", fields: [createdById], references: [id])
  items        OrderItem[]
  fees         OrderFee[]
  revisions    OrderRevision[]
  changeOrders ChangeOrder[]
  designs      DesignVersion[]
  productions  Production[]
  invoices     Invoice[]
  quotations   Quotation[]
  deliveries   Delivery[]
  costEntries  CostEntry[]
  goodsReceipts GoodsReceipt[]
  qcRecords    QcRecord[]
  printRunItems PrintRunItem[]
  filmStocks   FilmStock[]
  artworksSourced CustomerArtwork[] @relation("ArtworkSourceOrder")

  // hot paths: หน้า list กรองตามลูกค้า/สถานะ + เรียงตามวันที่สร้างแทบทุก query
  @@index([customerId])
  @@index([internalStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String   @map("order_id")
  sortOrder     Int      @default(0) @map("sort_order")
  description   String   @default("")
  totalQuantity Int      @default(0) @map("total_quantity")
  subtotal      Decimal  @default(0) @db.Decimal(12, 2)
  // tax-point เผื่อใบกำกับ P1: ขายสินค้า vs จ้างทำของ — จุดเกิด VAT ต่างกัน
  taxLineType   TaxLineType @default(HIRE_OF_WORK) @map("tax_line_type")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  order    Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  products OrderItemProduct[]
  prints   OrderItemPrint[]
  addons   OrderItemAddon[]

  @@map("order_items")
}

model OrderItemProduct {
  id                String   @id @default(cuid())
  orderItemId       String   @map("order_item_id")
  sortOrder         Int      @default(0) @map("sort_order")

  productId         String?  @map("product_id")
  productType       String   @map("product_type")
  description       String
  material          String?

  baseUnitPrice     Decimal  @map("base_unit_price") @db.Decimal(12, 2)
  discount          Decimal  @default(0) @db.Decimal(12, 2)
  totalQuantity     Int      @default(0) @map("total_quantity")
  subtotal          Decimal  @default(0) @db.Decimal(12, 2)

  itemSource        String?  @map("item_source")
  packagingOptionId String?  @map("packaging_option_id")

  fabricType        String?  @map("fabric_type")
  fabricWeight      String?  @map("fabric_weight")
  fabricColor       String?  @map("fabric_color")
  processingType    String?  @map("processing_type")

  patternId         String?  @map("pattern_id")
  collarType        String?  @map("collar_type")
  sleeveType        String?  @map("sleeve_type")
  bodyFit           String?  @map("body_fit")
  patternFileUrl    String?  @map("pattern_file_url")
  patternNote       String?  @map("pattern_note")

  garmentCondition  String?  @map("garment_condition")
  receivedInspected Boolean  @default(false) @map("received_inspected")
  receiveNote       String?  @map("receive_note")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
  pattern         Pattern?         @relation(fields: [patternId], references: [id])
  packagingOption PackagingOption? @relation(fields: [packagingOptionId], references: [id])
  variants        OrderItemVariant[]

  @@map("order_item_products")
}

model OrderItemVariant {
  id                  String   @id @default(cuid())
  orderItemProductId  String   @map("order_item_product_id")
  size                String
  color               String?
  quantity            Int
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  orderItemProduct OrderItemProduct @relation(fields: [orderItemProductId], references: [id], onDelete: Cascade)

  @@map("order_item_variants")
}

model OrderItemPrint {
  id             String   @id @default(cuid())
  orderItemId    String   @map("order_item_id")
  position       String   // FRONT, BACK, SLEEVE_L, SLEEVE_R, COLLAR, POCKET, OTHER
  printType      String   @map("print_type") // SILK_SCREEN, DTG, SUBLIMATION, HEAT_TRANSFER, EMBROIDERY
  colorCount     Int?     @map("color_count")
  printSize      String?  @map("print_size") // A5, A4, A3, A2, CUSTOM
  width          Float?
  height         Float?
  designNote     String?  @map("design_note")
  designImageUrl String?  @map("design_image_url")
  // ลิงก์เข้าคลังลายลูกค้า — FK ชี้ทางนี้เพราะ updateItems ลบ-สร้างแถวลายใหม่ทุกครั้ง (id ไม่เสถียร)
  // set ตอน QC ผ่าน (promote) หรือ duplicate พามา · ต้องร้อยครบ 4 จุด: printSchema/
  // mapPrintToMutationInput/mapApiItemsToForm/buildItemCreateData ไม่งั้นหายเงียบตอนแก้รายการ
  artworkId      String?  @map("artwork_id")
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2) // price per piece
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  orderItem OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  artwork   CustomerArtwork? @relation(fields: [artworkId], references: [id])

  @@index([artworkId])
  @@map("order_item_prints")
}

model OrderItemAddon {
  id          String   @id @default(cuid())
  orderItemId String   @map("order_item_id")
  addonType   String   @map("addon_type") // NECK_LABEL, SIZE_LABEL, CARE_LABEL, HANG_TAG, POLY_BAG, STICKER, BOX, EMBROIDERY, CUSTOM
  name        String
  description String?
  pricingType String   @map("pricing_type") // PER_PIECE or PER_ORDER
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  quantity    Int?     // override qty; null = use item totalQuantity
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_addons")
}

model OrderFee {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  feeType     String   @map("fee_type") // DESIGN_FEE, SCREEN_SETUP, DELIVERY, RUSH_FEE, SAMPLE_FEE, CUSTOM
  name        String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_fees")
}

model OrderRevision {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  version     Int
  changedBy   String   @map("changed_by")
  changeType  String   @map("change_type") // DESIGN, QUANTITY, MATERIAL, PRICE, STATUS, ADDON, etc.
  description String
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_revisions")
}

// ใบแก้ไขออเดอร์ (Change Order) — ออเดอร์อนุมัติแล้ว (DESIGN_APPROVED/PRODUCTION_QUEUE)
// แก้รายการ/ราคาผ่านใบนี้เท่านั้น · มีเลขเอกสาร CO + บันทึกยอดเก่า→ใหม่ + เหตุผล
// createdById เก็บ id เฉยๆ (ไม่ผูก relation User — เลียน OrderRevision.changedBy)
model ChangeOrder {
  id              String   @id @default(cuid())
  changeNumber    String   @unique @map("change_number") // CO-YYMM-NNNN
  orderId         String   @map("order_id")
  reason          String // เหตุผลการแก้ไข (บังคับกรอก)
  summary         String? // อะไรเปลี่ยน เช่น "แก้ไขรายการ + ค่าธรรมเนียม"
  oldTotal        Decimal  @map("old_total") @db.Decimal(12, 2)
  newTotal        Decimal  @map("new_total") @db.Decimal(12, 2)
  invoicedWarning Boolean  @default(false) @map("invoiced_warning") // ออกใบกำกับ/มัดจำไปแล้วตอนแก้ → ต้องออกใบลดหนี้/เพิ่มหนี้แยก
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("change_orders")
}

// ============================================================
// SERVICE CATALOG
// ============================================================

model ServiceCatalog {
  id           String   @id @default(cuid())
  category     String   // ADDON, PRINT, FEE
  type         String   // NECK_LABEL, SILK_SCREEN, DESIGN_FEE, etc.
  name         String
  description  String?
  defaultPrice Decimal  @map("default_price") @db.Decimal(12, 2)
  pricingType  String   @map("pricing_type") // PER_PIECE or PER_ORDER
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("service_catalog")
}

// ============================================================
// PATTERN CATALOG
// ============================================================

model Pattern {
  id           String   @id @default(cuid())
  name         String
  productType  String?  @map("product_type")
  collarType   String?  @map("collar_type")
  sleeveType   String?  @map("sleeve_type")
  bodyFit      String?  @map("body_fit")
  fileUrl      String?  @map("file_url")
  thumbnailUrl String?  @map("thumbnail_url")
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orderItemProducts OrderItemProduct[]

  @@map("patterns")
}

// ============================================================
// QUOTATION
// ============================================================

model Quotation {
  id              String    @id @default(cuid())
  quotationNumber String    @unique @map("quotation_number")
  orderId         String?   @map("order_id")
  customerId      String    @map("customer_id")
  createdById     String    @map("created_by_id")
  status          String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  title           String
  description     String?
  validUntil      DateTime  @map("valid_until")
  terms           String?
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  tax             Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  sentAt          DateTime? @map("sent_at")
  acceptedAt      DateTime? @map("accepted_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectedReason  String?   @map("rejected_reason")
  pdfUrl          String?   @map("pdf_url")
  notes           String?
  // ลิงก์ยืนยันใบเสนอให้ลูกค้า (ก้อน 4) — gate หมดอายุใช้ validUntil (ไม่มี expiry แยก)
  confirmToken    String?   @unique @map("confirm_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  customer  Customer        @relation(fields: [customerId], references: [id])
  createdBy User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  order     Order?          @relation(fields: [orderId], references: [id])
  items     QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String  @map("quotation_id")
  sortOrder   Int     @default(0) @map("sort_order")
  name        String
  description String?
  quantity    Int
  unit        String  @default("ชิ้น")
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  notes       String?

  // Relations
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

// ============================================================
// PRODUCT CATALOG (for READY_MADE orders)
// ============================================================

model Product {
  id              String    @id @default(cuid())
  sku             String    @unique
  name            String
  description     String?
  productType     String    @map("product_type") // T_SHIRT, POLO, HOODIE, TOTE_BAG
  category        String?
  basePrice       Decimal   @map("base_price") @db.Decimal(12, 2)
  costPrice       Decimal?  @map("cost_price") @db.Decimal(12, 2)
  imageUrl        String?   @map("image_url")
  images          String[]  @default([])
  isActive        Boolean   @default(true) @map("is_active")

  // Stock sync fields
  stockProductId  String?   @unique @map("stock_product_id")
  source          String    @default("STOCK") // "STOCK" | "LOCAL"
  itemType        String    @default("FINISHED_GOOD") @map("item_type") // FINISHED_GOOD, RAW_MATERIAL, CONSUMABLE
  barcode         String?
  unit            String?   // PCS, M, KG, etc.
  unitName        String?   @map("unit_name") // ชิ้น, เมตร, กก.
  reorderPoint    Float     @default(0) @map("reorder_point")
  totalStock      Int       @default(0) @map("total_stock")
  lastSyncAt      DateTime? @map("last_sync_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  variants          ProductVariant[]
  orderItemProducts OrderItemProduct[]
  materialUsages    MaterialUsage[]

  @@map("products")
}

model ProductVariant {
  id              String  @id @default(cuid())
  productId       String  @map("product_id")
  size            String
  color           String
  sku             String  @unique
  priceAdj        Decimal @default(0) @map("price_adj") @db.Decimal(12, 2)
  stock           Int     @default(0)
  isActive        Boolean @default(true) @map("is_active")

  // Stock sync fields
  stockVariantId  String? @unique @map("stock_variant_id")
  barcode         String?
  sellingPrice    Decimal @default(0) @map("selling_price") @db.Decimal(12, 2)
  costPrice       Decimal @default(0) @map("cost_price") @db.Decimal(12, 2)
  totalStock      Int     @default(0) @map("total_stock")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size, color])
  @@map("product_variants")
}

// ============================================================
// DELIVERY / SHIPPING
// ============================================================

model Delivery {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  recipientName   String    @map("recipient_name")
  phone           String
  address         String
  subDistrict     String?   @map("sub_district")
  district        String?
  province        String?
  postalCode      String?   @map("postal_code")
  shippingMethod  String    @map("shipping_method") // PICKUP, KERRY, FLASH, THAILAND_POST, J_AND_T, GRAB, LALAMOVE, SHOPEE_SHIP, LAZADA_SHIP, OTHER
  trackingNumber  String?   @map("tracking_number")
  shippingCost    Decimal   @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  isPaid          Boolean   @default(false) @map("is_paid")
  status          String    @default("PENDING") // PENDING, PREPARING, SHIPPED, DELIVERED, RETURNED
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  order Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lines DeliveryLine[]

  @@map("deliveries")
}

// รายการต่อกล่อง (FLOW-REDESIGN ก้อน 3) — แพ็คนับยืนยันต่อไซส์ + แบ่งส่งหลายรอบ
// "บอกได้ว่ากล่องไหนมีอะไร" · ใบส่ง 1 ใบ = 1 รอบส่ง · พิมพ์เป็นใบรายการแนบกล่องได้
model DeliveryLine {
  id          String  @id @default(cuid())
  deliveryId  String  @map("delivery_id")
  description String
  size        String?
  color       String?
  qty         Int

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_lines")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // ORDER_STATUS, DESIGN_APPROVAL, PAYMENT, DEADLINE, SYSTEM
  title       String
  message     String   @default("")
  link        String?
  isRead      Boolean  @default(false) @map("is_read")
  entityType  String?  @map("entity_type") // ORDER, INVOICE, etc.
  entityId    String?  @map("entity_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// COST TRACKING
// ============================================================

model CostEntry {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  category    String   // MATERIAL, LABOR, OUTSOURCE, OVERHEAD, PLATFORM_FEE, SHIPPING, OTHER
  name        String
  description String?
  // ที่มาอัตโนมัติ (step:<id> / outsource:<id>) — upsert ด้วย key นี้ กันต้นทุนซ้ำตอนแก้ค่า
  sourceRef   String?  @unique @map("source_ref")
  amount      Decimal  @db.Decimal(12, 2)
  quantity    Float?   // จำนวนหน่วยวัสดุ (เมตร/กก.) — ไม่ใช่เงิน คง Float
  unitCost    Decimal? @map("unit_cost") @db.Decimal(12, 2)
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User  @relation("CostCreatedBy", fields: [createdById], references: [id])

  @@map("cost_entries")
}

// ============================================================
// FILE ATTACHMENTS
// ============================================================

model Attachment {
  id           String   @id @default(cuid())
  entityType   String   @map("entity_type") // ORDER, CUSTOMER, QUOTATION, PRODUCTION, INVOICE
  entityId     String   @map("entity_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileType     String   @map("file_type") // image/png, application/pdf, etc.
  fileSize     Int      @map("file_size")
  category     String?  // ค่าที่รู้จัก + ชั้นไฟล์ (3 ชั้น) ดู src/lib/file-layers.ts — REFERENCE_IMAGE, PRINT_FILE (ชั้น 3 ภายในเท่านั้น), PO_DOCUMENT, PAYMENT_SLIP, PHOTO, OTHER
  printPosition String? @map("print_position") // FRONT, BACK, SLEEVE_L, SLEEVE_R, COLLAR, POCKET, OTHER (for REFERENCE_IMAGE)
  uploadedById String?  @map("uploaded_by_id") // null = ลูกค้าอัปผ่านลิงก์ token (ไม่มี user — ก้อน 4 ชิ้น 3)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  uploadedBy User? @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
  @@map("attachments")
}

// ============================================================
// DESIGN MANAGEMENT
// ============================================================

model DesignVersion {
  id              String               @id @default(cuid())
  orderId         String               @map("order_id")
  versionNumber   Int                  @map("version_number")
  fileUrl         String               @map("file_url")
  thumbnailUrl    String?              @map("thumbnail_url")
  approvalStatus  DesignApprovalStatus @default(PENDING) @map("approval_status")
  customerComment String?              @map("customer_comment")
  designerNotes   String?              @map("designer_notes")
  approvedAt      DateTime?            @map("approved_at")
  approvalToken   String?              @unique @map("approval_token")
  tokenExpiresAt  DateTime?            @map("token_expires_at")
  createdAt       DateTime             @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, versionNumber])
  @@map("design_versions")
}

// ============================================================
// GOODS RECEIPT — ใบตรวจรับของเข้า + ใบคืนของลูกค้า (FLOW-REDESIGN ก้อน 1)
// มตินับของ 2 จุด: ของเข้าโรงงาน (ใบนี้) + QC ก่อนแพ็ค (ก้อน 3) — ระหว่างทางไม่บังคับนับ
// ============================================================

model GoodsReceipt {
  id               String   @id @default(cuid())
  orderId          String   @map("order_id")
  // CUSTOMER_GARMENT รับเสื้อลูกค้า · SEWING_GARMENT รับเสื้อโรงเย็บ ·
  // OUTSOURCE_RETURN รับกลับร้านนอก · CUSTOMER_RETURN คืนของลูกค้า (ยอดคืนหักจากยอดรับ)
  receiptType      String   @map("receipt_type")
  outsourceOrderId String?  @map("outsource_order_id")
  notes            String?
  photoUrls        String[] @default([]) @map("photo_urls")
  receivedById     String   @map("received_by_id")
  receivedAt       DateTime @default(now()) @map("received_at")
  createdAt        DateTime @default(now()) @map("created_at")

  order      Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  receivedBy User               @relation("GoodsReceivedBy", fields: [receivedById], references: [id])
  lines      GoodsReceiptLine[]

  @@index([orderId])
  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id                 String  @id @default(cuid())
  receiptId          String  @map("receipt_id")
  orderItemProductId String? @map("order_item_product_id")
  description        String
  size               String?
  color              String?
  qtyExpected        Int     @default(0) @map("qty_expected")
  qtyCounted         Int     @map("qty_counted")
  defectQty          Int     @default(0) @map("defect_qty")
  defectNote         String? @map("defect_note")

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("goods_receipt_lines")
}

// ============================================================
// QC เชิงนับ (FLOW-REDESIGN ก้อน 3) — นับของจุดที่ 2: ตรวจก่อนแพ็ค
// "ดีกี่ตัว เสียกี่ตัว" · ของเสียบันทึกเป็นตัวเลข ไซส์×ลาย×สาเหตุ×รูป
// (เดิมเป็นช่องข้อความ รวมยอด/หาสาเหตุบ่อยไม่ได้) — รายงานของเสียรายเดือนได้ฟรี
// กรอกเฉพาะตอนมีของเสีย — ของดีล้วนกดบันทึกเดียวจบ (ห้ามเพิ่มงานกรอกหน้างาน)
// ============================================================

model QcRecord {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  qtyGood     Int      @map("qty_good")
  qtyDefect   Int      @default(0) @map("qty_defect") // denorm = sum(defects.qty)
  notes       String?
  checkedById String   @map("checked_by_id")
  checkedAt   DateTime @default(now()) @map("checked_at")
  createdAt   DateTime @default(now()) @map("created_at")

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  checkedBy User       @relation("QcCheckedBy", fields: [checkedById], references: [id])
  defects   QcDefect[]

  @@index([orderId])
  @@index([checkedAt])
  @@map("qc_records")
}

model QcDefect {
  id         String   @id @default(cuid())
  qcRecordId String   @map("qc_record_id")
  qty        Int
  size       String?
  color      String?
  printLabel String?  @map("print_label") // ลายไหน (ตำแหน่ง/ชื่อลาย — งานหลายลายชี้ตัวปัญหาได้)
  reason     String // รหัสสาเหตุ — ค่า/ป้ายไทยใน src/lib/qc.ts (รวมยอดต่อสาเหตุได้)
  photoUrls  String[] @default([]) @map("photo_urls")
  note       String?

  qcRecord QcRecord @relation(fields: [qcRecordId], references: [id], onDelete: Cascade)

  @@index([reason])
  @@map("qc_defects")
}

// ============================================================
// PRODUCTION
// ============================================================

model Production {
  id          String     @id @default(cuid())
  orderId     String     @map("order_id")
  status      StepStatus @default(PENDING)
  startDate   DateTime?  @map("start_date")
  endDate     DateTime?  @map("end_date")
  totalCost   Decimal    @default(0) @map("total_cost") @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  steps          ProductionStep[]
  materialUsages MaterialUsage[]

  @@map("productions")
}

model MaterialUsage {
  id               String    @id @default(cuid())
  productionId     String    @map("production_id")
  productId        String    @map("product_id")
  productVariantId String?   @map("product_variant_id")
  quantity         Float
  unit             String
  unitCost         Decimal   @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalCost        Decimal   @default(0) @map("total_cost") @db.Decimal(12, 2)
  // ทิศทาง: ISSUE = เบิกออกจากสต๊อค · RETURN = คืนเศษกลับสต๊อค (qty เป็นบวกเสมอ
  // ยอดสุทธิ = sum(ISSUE) − sum(RETURN)) — ใบเบิกเสื้อ FLOW-REDESIGN ก้อน 1
  movementType     String    @default("ISSUE") @map("movement_type")
  note             String?
  stockMovementRef String?   @map("stock_movement_ref")
  deductedAt       DateTime? @map("deducted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("material_usages")
}

model ProductionStep {
  id             String             @id @default(cuid())
  productionId   String             @map("production_id")
  stepType       ProductionStepType @map("step_type")
  customStepName String?            @map("custom_step_name")
  status         StepStatus         @default(PENDING)
  sortOrder      Int                @map("sort_order")
  // หน่วยงานจริงคือ "กองเสื้อ" — บอกบางส่วนได้ (ทำแล้ว 120/300) · qtyTotal null = ขั้นแบบติ๊กเฉยๆ
  qtyDone        Int                @default(0) @map("qty_done")
  qtyTotal       Int?               @map("qty_total")
  assignedToId   String?            @map("assigned_to_id")
  startedAt      DateTime?          @map("started_at")
  completedAt    DateTime?          @map("completed_at")
  estimatedCost  Decimal?           @map("estimated_cost") @db.Decimal(12, 2)
  actualCost     Decimal?           @map("actual_cost") @db.Decimal(12, 2)
  qcPassed       Boolean?           @map("qc_passed")
  qcNotes        String?            @map("qc_notes")
  notes          String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // Relations
  production      Production       @relation(fields: [productionId], references: [id], onDelete: Cascade)
  assignedTo      User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  outsourceOrders OutsourceOrder[]
  printRunItems   PrintRunItem[]

  // hot path: task queue "งานของฉัน" กรองตามคนรับผิดชอบ
  @@index([assignedToId])
  @@map("production_steps")
}

// ============================================================
// PRINT RUN — รอบพิมพ์ฟิล์ม DTF (FLOW-REDESIGN ก้อน 2)
// ความจริงหน้าเครื่อง: ช่างพิมพ์รวมหลายงานลงม้วนเดียว กดเสร็จเป็นชุด
// จากนั้นต้องผ่านจุด "ตัดแยก+ติดป้าย" (กันฟิล์มสลับออเดอร์) ก่อนขั้น
// DTF_PRINT ของงานสมาชิกจะถูกนับ/ปิด — ฟิล์มพิมพ์เผื่อเข้าคลัง FilmStock
// ============================================================

enum PrintRunStatus {
  PRINTING // เปิดรอบแล้ว — กำลังจัดวาง/พิมพ์/โรยผง/อบ
  PRINTED // พิมพ์จบทั้งม้วน — รอตัดแยกฟิล์ม + ติดป้าย
  COMPLETED // ตัดแยก+ติดป้ายเสร็จ — ขั้น DTF_PRINT ของสมาชิกถูกนับแล้ว
  CANCELLED // ยกเลิกก่อนพิมพ์ — งานคืนกลับคิว
}

model PrintRun {
  id          String         @id @default(cuid())
  runNumber   String         @unique @map("run_number") // FR-YYMM-NNNN ผ่าน DocumentSequence
  status      PrintRunStatus @default(PRINTING)
  note        String?
  createdById String         @map("created_by_id")
  printedAt   DateTime?      @map("printed_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  createdBy  User           @relation("PrintRunCreatedBy", fields: [createdById], references: [id])
  items      PrintRunItem[]
  filmStocks FilmStock[]

  @@index([status])
  @@map("print_runs")
}

model PrintRunItem {
  id               String   @id @default(cuid())
  printRunId       String   @map("print_run_id")
  productionStepId String   @map("production_step_id")
  orderId          String   @map("order_id") // denorm — โชว์คิว/ป้ายไม่ต้อง join ลึก
  qty              Int // จำนวนชิ้นของงานนี้ที่พิมพ์ในรอบนี้ (แบ่งพิมพ์หลายรอบได้)
  extraQty         Int      @default(0) @map("extra_qty") // พิมพ์เผื่อ — กรอกตอนปิดรอบ → เข้าคลังฟิล์ม
  createdAt        DateTime @default(now()) @map("created_at")

  printRun       PrintRun       @relation(fields: [printRunId], references: [id], onDelete: Cascade)
  productionStep ProductionStep @relation(fields: [productionStepId], references: [id])
  order          Order          @relation(fields: [orderId], references: [id])

  @@index([productionStepId])
  @@index([printRunId])
  @@map("print_run_items")
}

// คลังฟิล์มพร้อมรีด — ฟิล์มพิมพ์เผื่อ "ลายไหน ของลูกค้าไหน เหลือกี่ชิ้น"
// ลูกค้าสั่งซ้ำ → เช็คก่อนว่ามีฟิล์มค้าง รีดได้เลยไม่ต้องพิมพ์ใหม่
model FilmStock {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  orderId    String?  @map("order_id") // ออเดอร์ต้นทางของลาย
  printRunId String?  @map("print_run_id") // รอบพิมพ์ที่ผลิตฟิล์มก้อนนี้
  // ลิงก์เข้าคลังลาย (ก้อน 4 ชิ้น 2) — set เมื่อระบุได้ไม่กำกวม (ออเดอร์มีลายเดียว/ลายผูกคลังแล้ว)
  // ฟิล์มเก่า/กำกวมเป็น null — เช็คฟิล์มค้างถอยไปจับระดับลูกค้าแทน
  artworkId  String?  @map("artwork_id")
  label      String // ป้ายลาย เช่น "โลโก้อกซ้าย 8cm ดำ"
  qty        Int // คงเหลือ (ชิ้น) — หยิบใช้แล้วลด ห้ามติดลบ
  initialQty Int      @map("initial_qty") // จำนวนตอนเข้าคลัง (ไว้ตรวจย้อน)
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer         @relation(fields: [customerId], references: [id])
  order    Order?           @relation(fields: [orderId], references: [id])
  printRun PrintRun?        @relation(fields: [printRunId], references: [id])
  artwork  CustomerArtwork? @relation(fields: [artworkId], references: [id])

  @@index([customerId])
  @@index([artworkId])
  @@map("film_stocks")
}

// ============================================================
// OUTSOURCE
// ============================================================

model Vendor {
  id             String   @id @default(cuid())
  name           String
  contactName    String?  @map("contact_name")
  phone          String?
  email          String?
  lineId         String?  @map("line_id")
  address        String?
  capabilities   String[] @default([])
  qualityRating  Float?   @map("quality_rating")
  timeRating     Float?   @map("time_rating")
  priceRating    Float?   @map("price_rating")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  outsourceOrders OutsourceOrder[]

  @@map("vendors")
}

// หนึ่ง step ส่งร้านนอกได้หลายรอบ (งาน QC ไม่ผ่านส่งกลับแก้เป็นรอบใหม่) —
// แต่มีงานค้างที่ร้าน (ยังไม่จบ QC) ได้ทีละใบ บังคับที่ outsource.createOrder
model OutsourceOrder {
  id               String          @id @default(cuid())
  productionStepId String          @map("production_step_id")
  vendorId         String          @map("vendor_id")
  status           OutsourceStatus @default(DRAFT)
  description      String
  quantity         Int
  unitCost         Decimal         @map("unit_cost") @db.Decimal(12, 2)
  totalCost        Decimal         @map("total_cost") @db.Decimal(12, 2)
  sentAt           DateTime?       @map("sent_at")
  expectedBackAt   DateTime?       @map("expected_back_at")
  receivedAt       DateTime?       @map("received_at")
  qcPassed         Boolean?        @map("qc_passed")
  qcNotes          String?         @map("qc_notes")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  productionStep ProductionStep @relation(fields: [productionStepId], references: [id], onDelete: Cascade)
  vendor         Vendor         @relation(fields: [vendorId], references: [id])

  @@index([productionStepId])
  @@index([status])
  @@map("outsource_orders")
}

// ============================================================
// BILLING & INVOICE
// ============================================================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @map("invoice_number")
  orderId       String        @map("order_id")
  customerId    String        @map("customer_id")
  type          InvoiceType
  amount        Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  dueDate       DateTime?     @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  isVoided      Boolean       @default(false) @map("is_voided")
  voidedReason  String?       @map("voided_reason")
  notes         String?
  // ใบลดหนี้/เพิ่มหนี้ต้องอ้างใบกำกับเดิม + เหตุผล (ม.86/10 + ป.80/2542) — บังคับที่
  // billing.create เมื่อ type CN/DN · ใบลดหนี้ที่ผูกใบเรียกเก็บ = หักยอดค้างของใบนั้นจริง
  originalInvoiceId String? @map("original_invoice_id")
  adjustmentReason  String? @map("adjustment_reason")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  order            Order             @relation(fields: [orderId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  payments         Payment[]
  billingNoteItems BillingNoteItem[]
  whtCertificates  WhtCertificate[]
  // Restrict — กติกา "ห้ามลบใบ": ใบเดิมที่มี CN/DN อ้างอยู่ห้ามหายแม้ทาง SQL/admin
  originalInvoice  Invoice?          @relation("InvoiceAdjustments", fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  adjustments      Invoice[]         @relation("InvoiceAdjustments")

  // hot path: หน้า billing + stats กรองตามสถานะจ่ายตลอด
  @@index([paymentStatus])
  // ตามหาใบลดหนี้/เพิ่มหนี้ของใบเดิม (outstanding ต้องหักทุกครั้งที่อ่านลูกหนี้)
  @@index([originalInvoiceId])
  @@map("invoices")
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String   @map("invoice_id")
  amount        Decimal  @db.Decimal(12, 2)
  // ลูกค้านิติบุคคลหัก ณ ที่จ่าย 3% ค่าจ้างทำของ — รับเงินสด 97% + เครดิตภาษี 3%
  // ยอดที่ "เคลียร์บิล" = amount + whtAmount (กันบิลค้างผี/โดน overdue sweep ปลอม)
  // ส่วนยอดเงินสดจริง (สถิติรับเงิน) ใช้ amount อย่างเดียวเสมอ
  whtAmount     Decimal  @default(0) @map("wht_amount") @db.Decimal(12, 2)
  method        String   // CASH, TRANSFER, CARD, QR
  reference     String?
  evidenceUrl   String?  @map("evidence_url")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  invoice        Invoice         @relation(fields: [invoiceId], references: [id])
  whtCertificate WhtCertificate?

  @@map("payments")
}

// ทะเบียนหัก ณ ที่จ่ายขารับ (50ทวิ) — ลูกค้าเป็นผู้ออกหนังสือรับรองให้เรา
// เกิดอัตโนมัติเมื่อบันทึกรับเงินที่มี whtAmount > 0 · ตามทวงใบจริงจากลูกค้า
// (เครดิตภาษีปลายปี — ไม่มีใบ = เงิน 3% หายฟรี) · export CSV ให้นักบัญชี
model WhtCertificate {
  id          String    @id @default(cuid())
  paymentId   String    @unique @map("payment_id")
  invoiceId   String    @map("invoice_id") // denorm — ทะเบียน/export ไม่ต้อง join ลึก
  customerId  String    @map("customer_id")
  baseAmount  Decimal   @map("base_amount") @db.Decimal(12, 2) // ฐานก่อน VAT ที่ลูกค้าใช้หัก
  ratePct     Decimal   @default(3) @map("rate_pct") @db.Decimal(5, 2)
  amount      Decimal   @db.Decimal(12, 2) // ยอดภาษีที่ถูกหัก
  certNumber  String?   @map("cert_number") // เลขที่หนังสือรับรอง (ลูกค้าออก — กรอกตอนได้ใบ)
  certDate    DateTime? @map("cert_date")
  received    Boolean   @default(false) // ได้ใบจริง/สแกนจากลูกค้าแล้ว
  receivedAt  DateTime? @map("received_at")
  fileUrl     String?   @map("file_url") // สแกนหนังสือรับรอง
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  payment  Payment  @relation(fields: [paymentId], references: [id])
  invoice  Invoice  @relation(fields: [invoiceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  // hot path: ทะเบียนกรอง "ยังไม่ได้ใบ" เป็นหลัก
  @@index([received])
  @@index([customerId])
  @@map("wht_certificates")
}

// ใบวางบิล — รวมใบแจ้งหนี้ค้างชำระของลูกค้ารายเดียวเพื่อเรียกเก็บตามรอบ (B2B เครดิตเทอม)
// ยกเลิก-ออกใหม่เท่านั้น ห้ามลบ (convention เดียวกับ Invoice)
model BillingNote {
  id                String    @id @default(cuid())
  billingNoteNumber String    @unique @map("billing_note_number")
  customerId        String    @map("customer_id")
  billingDate       DateTime  @default(now()) @map("billing_date")
  dueDate           DateTime? @map("due_date") // วันนัดรับชำระ
  totalAmount       Decimal   @map("total_amount") @db.Decimal(12, 2) // ยอดคงเหลือรวม ณ วันวางบิล
  isVoided          Boolean   @default(false) @map("is_voided")
  voidedReason      String?   @map("voided_reason")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  customer Customer          @relation(fields: [customerId], references: [id])
  items    BillingNoteItem[]

  @@index([customerId])
  @@map("billing_notes")
}

model BillingNoteItem {
  id            String  @id @default(cuid())
  billingNoteId String  @map("billing_note_id")
  invoiceId     String  @map("invoice_id")
  amount        Decimal @db.Decimal(12, 2) // ยอดคงเหลือของใบแจ้งหนี้ ณ วันวางบิล (snapshot)

  // Relations
  billingNote BillingNote @relation(fields: [billingNoteId], references: [id], onDelete: Cascade)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id])

  @@unique([billingNoteId, invoiceId])
  @@index([invoiceId])
  @@map("billing_note_items")
}

// ============================================================
// APPROVAL WORKFLOW
// ============================================================

model ApprovalRequest {
  id           String         @id @default(cuid())
  requesterId  String         @map("requester_id")
  approverId   String?        @map("approver_id")
  entityType   String         @map("entity_type")
  entityId     String         @map("entity_id")
  action       String
  reason       String
  status       ApprovalStatus @default(PENDING)
  approvedAt   DateTime?      @map("approved_at")
  rejectedAt   DateTime?      @map("rejected_at")
  rejectReason String?        @map("reject_reason")
  createdAt    DateTime       @default(now()) @map("created_at")

  // Relations
  requester User  @relation("Requester", fields: [requesterId], references: [id])
  approver  User? @relation("Approver", fields: [approverId], references: [id])

  @@map("approval_requests")
}

// ============================================================
// PACKAGING OPTIONS
// ============================================================

model PackagingOption {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItemProducts OrderItemProduct[]

  @@map("packaging_options")
}

// ============================================================
// SETTINGS (Key-Value Store)
// ============================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ============================================================
// DOCUMENT NUMBERING — เลขเอกสารรันต่อเนื่องต่อชนิด/เดือน (ห้ามสุ่ม — กฎหมายใบกำกับภาษี)
// ============================================================

model DocumentSequence {
  id         String   @id @default(cuid())
  docType    String   @map("doc_type") // ORDER, QUOTATION, DEPOSIT_INVOICE, FINAL_INVOICE, RECEIPT, CREDIT_NOTE, DEBIT_NOTE
  period     String   // YYMM เช่น "2606" — เลขรีเซ็ตต่อเดือนตาม format เลขเอกสารเดิม
  lastNumber Int      @default(0) @map("last_number")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([docType, period])
  @@map("document_sequences")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  reason     String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
