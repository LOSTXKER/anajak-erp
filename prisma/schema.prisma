// Prisma Schema for Anajak ERP
// This schema is based on the SQL migration: 20241205000001_phase1_core_schema.sql

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// USER PROFILES
// =============================================
model UserProfile {
  id                   String    @id @db.Uuid
  email                String    @unique
  fullName             String?   @map("full_name")
  displayName          String?   @map("display_name")
  phone                String?
  avatarUrl            String?   @map("avatar_url")
  role                 String    @default("staff")
  department           String?
  canApproveDesigns    Boolean   @default(false) @map("can_approve_designs")
  canApproveOrders     Boolean   @default(false) @map("can_approve_orders")
  canManageInventory   Boolean   @default(false) @map("can_manage_inventory")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  customersAsigned     Customer[]        @relation("AssignedSales")
  ordersCreated        Order[]           @relation("OrderCreator")
  ordersAssigned       Order[]           @relation("AssignedSales")
  ordersProduction     Order[]           @relation("AssignedProduction")
  changeRequestsQuoted ChangeRequest[]   @relation("QuotedBy")
  changeRequestsCreated ChangeRequest[]  @relation("CreatedBy")
  approvalGates        ApprovalGate[]
  designsUploaded      DesignVersion[]   @relation("DesignUploader")
  designsApproved      DesignVersion[]   @relation("DesignApprover")
  designsRejected      DesignVersion[]   @relation("DesignRejecter")
  productionJobs       ProductionJob[]   @relation("ProductionWorker")
  qcInspections        QcRecord[]        @relation("QcInspector")

  @@map("user_profiles")
}

// =============================================
// CUSTOMERS
// =============================================
model Customer {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCode       String    @unique @map("customer_code")
  customerType       String    @default("individual") @map("customer_type")
  companyName        String?   @map("company_name")
  contactPerson      String    @map("contact_person")
  email              String?
  phone              String
  lineId             String?   @map("line_id")
  address            String?
  district           String?
  city               String?
  province           String?
  postalCode         String?   @map("postal_code")
  taxId              String?   @map("tax_id")
  branch             String    @default("สำนักงานใหญ่")
  assignedSalesId    String?   @map("assigned_sales_id") @db.Uuid
  customerTier       String    @default("standard") @map("customer_tier")
  discountPercentage Decimal   @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  creditLimit        Decimal   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  creditDays         Int       @default(0) @map("credit_days")
  totalOrders        Int       @default(0) @map("total_orders")
  totalRevenue       Decimal   @default(0) @map("total_revenue") @db.Decimal(15, 2)
  lastOrderDate      DateTime? @map("last_order_date") @db.Date
  isActive           Boolean   @default(true) @map("is_active")
  notes              String?
  tags               String[]
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  assignedSales      UserProfile? @relation("AssignedSales", fields: [assignedSalesId], references: [id])
  orders             Order[]
  quotations         Quotation[]
  invoices           Invoice[]

  @@map("customers")
}

// =============================================
// PRODUCTS
// =============================================
model Product {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku                 String    @unique
  productType         String    @map("product_type")
  name                String
  nameTh              String    @map("name_th")
  description         String?
  materialType        String?   @map("material_type")
  weightGsm           Int?      @map("weight_gsm")
  baseColor           String?   @map("base_color")
  availableSizes      String[]  @map("available_sizes")
  costPrice           Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  basePrice           Decimal   @map("base_price") @db.Decimal(10, 2)
  trackInventory      Boolean   @default(true) @map("track_inventory")
  lowStockThreshold   Int       @default(10) @map("low_stock_threshold")
  imageUrl            String?   @map("image_url")
  mockupTemplateUrl   String?   @map("mockup_template_url")
  isActive            Boolean   @default(true) @map("is_active")
  isFeatured          Boolean   @default(false) @map("is_featured")
  slug                String?   @unique
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  orderItems          OrderItem[]
  quotationItems      QuotationItem[]

  @@map("products")
}

// =============================================
// MATERIALS
// =============================================
model Material {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String    @unique
  name                String
  nameTh              String    @map("name_th")
  category            String    // fabric, thread, ink, label, packaging
  unit                String    @default("pcs")
  costPrice           Decimal   @default(0) @map("cost_price") @db.Decimal(10, 2)
  currentStock        Decimal   @default(0) @map("current_stock") @db.Decimal(10, 2)
  reservedStock       Decimal   @default(0) @map("reserved_stock") @db.Decimal(10, 2)
  lowStockThreshold   Decimal   @default(10) @map("low_stock_threshold") @db.Decimal(10, 2)
  isActive            Boolean   @default(true) @map("is_active")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  purchaseRequests    PurchaseRequest[]

  @@map("materials")
}

// =============================================
// ORDER TYPES
// =============================================
model OrderType {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  nameTh          String   @map("name_th")
  description     String?
  defaultLeadDays Int      @default(7) @map("default_lead_days")
  requiresPattern Boolean  @default(false) @map("requires_pattern")
  requiresFabric  Boolean  @default(false) @map("requires_fabric")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  orders          Order[]

  @@map("order_types")
}

// =============================================
// ORDERS
// =============================================
model Order {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber            String    @unique @map("order_number")
  customerId             String    @map("customer_id") @db.Uuid
  customerName           String    @map("customer_name")
  customerPhone          String?   @map("customer_phone")
  orderTypeCode          String    @default("ready_made") @map("order_type_code")
  orderDate              DateTime  @default(now()) @map("order_date") @db.Date
  dueDate                DateTime? @map("due_date") @db.Date
  productionMode         String    @default("in_house") @map("production_mode")
  priorityLevel          Int       @default(0) @map("priority_level")
  prioritySurcharge      Decimal   @default(0) @map("priority_surcharge") @db.Decimal(10, 2)
  revisionCount          Int       @default(0) @map("revision_count")
  freeRevisions          Int       @default(2) @map("free_revisions")
  allDesignsApproved     Boolean   @default(false) @map("all_designs_approved")
  mockupApproved         Boolean   @default(false) @map("mockup_approved")
  mockupApprovedAt       DateTime? @map("mockup_approved_at") @db.Timestamptz
  materialsReady         Boolean   @default(false) @map("materials_ready")
  productionUnlocked     Boolean   @default(false) @map("production_unlocked")
  changeRequestCount     Int       @default(0) @map("change_request_count")
  changeRequestTotal     Decimal   @default(0) @map("change_request_total") @db.Decimal(12, 2)
  subtotal               Decimal   @default(0) @db.Decimal(12, 2)
  discountAmount         Decimal   @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountPercentage     Decimal   @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  taxAmount              Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  shippingFee            Decimal   @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  totalAmount            Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  paymentStatus          String    @default("unpaid") @map("payment_status")
  paidAmount             Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status                 String    @default("draft")
  deliveryMethod         String?   @map("delivery_method")
  deliveryAddress        String?   @map("delivery_address")
  trackingNumber         String?   @map("tracking_number")
  shippedAt              DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt            DateTime? @map("delivered_at") @db.Timestamptz
  notes                  String?
  internalNotes          String?   @map("internal_notes")
  assignedSalesId        String?   @map("assigned_sales_id") @db.Uuid
  assignedProductionId   String?   @map("assigned_production_id") @db.Uuid
  createdBy              String?   @map("created_by") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  completedAt            DateTime? @map("completed_at") @db.Timestamptz
  cancelledAt            DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason     String?   @map("cancellation_reason")

  // Relations
  customer               Customer     @relation(fields: [customerId], references: [id])
  orderType              OrderType?   @relation(fields: [orderTypeCode], references: [code])
  assignedSales          UserProfile? @relation("AssignedSales", fields: [assignedSalesId], references: [id])
  assignedProduction     UserProfile? @relation("AssignedProduction", fields: [assignedProductionId], references: [id])
  creator                UserProfile? @relation("OrderCreator", fields: [createdBy], references: [id])
  items                  OrderItem[]
  addons                 OrderAddon[]
  approvalGates          ApprovalGate[]
  changeRequests         ChangeRequest[]
  productionJobs         ProductionJob[]
  productionIssues       ProductionIssue[]
  outsourceJobs          OutsourceJob[]
  purchaseRequests       PurchaseRequest[]
  invoices               Invoice[]
  shipments              Shipment[]

  @@map("orders")
}

// =============================================
// ORDER ITEMS
// =============================================
model OrderItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String    @map("order_id") @db.Uuid
  itemNumber       Int       @map("item_number")
  productId        String?   @map("product_id") @db.Uuid
  productSku       String?   @map("product_sku")
  productName      String    @map("product_name")
  size             String?
  color            String?
  quantity         Int       @default(1)
  unitPrice        Decimal   @map("unit_price") @db.Decimal(10, 2)
  lineTotal        Decimal   @map("line_total") @db.Decimal(12, 2)
  designFiles      String[]  @map("design_files")
  designStatus     String    @default("pending") @map("design_status")
  mockupUrl        String?   @map("mockup_url")
  productionStatus String    @default("pending") @map("production_status")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?  @relation(fields: [productId], references: [id])
  designVersions   DesignVersion[]
  productionJobs   ProductionJob[]

  @@unique([orderId, itemNumber])
  @@map("order_items")
}

// =============================================
// ADDON TYPES
// =============================================
model AddonType {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  nameTh          String   @map("name_th")
  category        String
  basePrice       Decimal  @default(0) @map("base_price") @db.Decimal(10, 2)
  priceType       String   @default("per_piece") @map("price_type")
  requiresDesign  Boolean  @default(false) @map("requires_design")
  requiresMaterial Boolean @default(false) @map("requires_material")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  orderAddons     OrderAddon[]

  @@map("addon_types")
}

// =============================================
// ORDER ADDONS
// =============================================
model OrderAddon {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String?    @map("order_id") @db.Uuid
  orderItemId   String?    @map("order_item_id") @db.Uuid
  addonTypeId   String?    @map("addon_type_id") @db.Uuid
  addonCode     String     @map("addon_code")
  addonName     String     @map("addon_name")
  quantity      Int        @default(1)
  unitPrice     Decimal    @default(0) @map("unit_price") @db.Decimal(10, 2)
  totalPrice    Decimal    @default(0) @map("total_price") @db.Decimal(12, 2)
  status        String     @default("pending")
  designFileUrl String?    @map("design_file_url")
  designStatus  String?    @map("design_status")
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  order         Order?     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addonType     AddonType? @relation(fields: [addonTypeId], references: [id])

  @@map("order_addons")
}

// =============================================
// APPROVAL GATES
// =============================================
model ApprovalGate {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId              String    @map("order_id") @db.Uuid
  gateType             String    @map("gate_type")
  gateName             String    @map("gate_name")
  status               String    @default("pending")
  approvedBy           String?   @map("approved_by") @db.Uuid
  approvedAt           DateTime? @map("approved_at") @db.Timestamptz
  customerConfirmedAt  DateTime? @map("customer_confirmed_at") @db.Timestamptz
  customerIp           String?   @map("customer_ip")
  customerSignature    String?   @map("customer_signature")
  notes                String?
  rejectionReason      String?   @map("rejection_reason")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  order                Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approver             UserProfile? @relation(fields: [approvedBy], references: [id])

  @@map("approval_gates")
}

// =============================================
// DESIGN VERSION TRACKING
// =============================================
model DesignVersion {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderItemId      String    @map("order_item_id") @db.Uuid
  versionNumber    Int       @map("version_number")
  designFiles      String[]  @map("design_files")
  mockupUrl        String?   @map("mockup_url")
  status           String    @default("draft")
  uploadedBy       String?   @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz
  approvedBy       String?   @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz
  rejectedBy       String?   @map("rejected_by") @db.Uuid
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason  String?   @map("rejection_reason")
  revisionNotes    String?   @map("revision_notes")
  isCurrentVersion Boolean   @default(false) @map("is_current_version")
  isBillable       Boolean   @default(false) @map("is_billable")
  revisionFee      Decimal   @default(0) @map("revision_fee") @db.Decimal(10, 2)

  // Relations
  orderItem        OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  uploader         UserProfile? @relation("DesignUploader", fields: [uploadedBy], references: [id])
  approver         UserProfile? @relation("DesignApprover", fields: [approvedBy], references: [id])
  rejecter         UserProfile? @relation("DesignRejecter", fields: [rejectedBy], references: [id])

  @@map("design_versions")
  @@index([orderItemId, versionNumber])
}

// =============================================
// CHANGE REQUESTS
// =============================================
model ChangeRequest {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestNumber       String    @unique @map("request_number")
  orderId             String    @map("order_id") @db.Uuid
  orderPhase          String    @map("order_phase")
  changeType          String    @map("change_type")
  description         String
  affectedWorkItems   String[]  @map("affected_work_items") @db.Uuid
  baseFee             Decimal   @default(0) @map("base_fee") @db.Decimal(10, 2)
  designFee           Decimal   @default(0) @map("design_fee") @db.Decimal(10, 2)
  reworkFee           Decimal   @default(0) @map("rework_fee") @db.Decimal(10, 2)
  materialFee         Decimal   @default(0) @map("material_fee") @db.Decimal(10, 2)
  totalFee            Decimal   @default(0) @map("total_fee") @db.Decimal(12, 2)
  daysDelayed         Int       @default(0) @map("days_delayed")
  newDueDate          DateTime? @map("new_due_date") @db.Date
  status              String    @default("pending")
  quotedAt            DateTime? @map("quoted_at") @db.Timestamptz
  quotedBy            String?   @map("quoted_by") @db.Uuid
  customerApprovedAt  DateTime? @map("customer_approved_at") @db.Timestamptz
  paymentStatus       String    @default("unpaid") @map("payment_status")
  referenceFiles      String[]  @map("reference_files")
  customerReason      String?   @map("customer_reason")
  adminNotes          String?   @map("admin_notes")
  createdBy           String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quoter              UserProfile? @relation("QuotedBy", fields: [quotedBy], references: [id])
  creator             UserProfile? @relation("CreatedBy", fields: [createdBy], references: [id])

  @@map("change_requests")
}

// =============================================
// WORK TYPES
// =============================================
model WorkType {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique
  name               String
  nameTh             String    @map("name_th")
  category           String    // PRINTING, EMBROIDERY, GARMENT, LABELING, FINISHING
  requiresDesign     Boolean   @default(false) @map("requires_design")
  requiresMaterial   Boolean   @default(false) @map("requires_material")
  defaultPrice       Decimal   @default(0) @map("default_price") @db.Decimal(10, 2)
  sortOrder          Int       @default(0) @map("sort_order")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("work_types")
}

// =============================================
// PRODUCTION MANAGEMENT
// =============================================
model ProductionJob {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobNumber         String    @unique @map("job_number")
  orderId           String    @map("order_id") @db.Uuid
  orderItemId       String?   @map("order_item_id") @db.Uuid
  workType          String    @map("work_type")
  workName          String    @map("work_name")
  quantity          Int
  priorityScore     Int       @default(50) @map("priority_score")
  status            String    @default("queued")
  assignedTo        String?   @map("assigned_to") @db.Uuid
  machineId         String?   @map("machine_id")
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  completedAt       DateTime? @map("completed_at") @db.Timestamptz
  actualQuantity    Int       @default(0) @map("actual_quantity")
  defectQuantity    Int       @default(0) @map("defect_quantity")
  reworkQuantity    Int       @default(0) @map("rework_quantity")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem         OrderItem?   @relation(fields: [orderItemId], references: [id])
  worker            UserProfile? @relation("ProductionWorker", fields: [assignedTo], references: [id])
  qcRecords         QcRecord[]
  productionIssues  ProductionIssue[]

  @@map("production_jobs")
  @@index([status, priorityScore])
}

model QcStage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String    @unique
  name             String
  nameTh           String    @map("name_th")
  description      String?
  checklistItems   String[]  @map("checklist_items")
  sortOrder        Int       @default(0) @map("sort_order")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  qcRecords        QcRecord[]

  @@map("qc_stages")
}

model QcRecord {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productionJobId    String    @map("production_job_id") @db.Uuid
  qcStageId          String    @map("qc_stage_id") @db.Uuid
  inspectedBy        String?   @map("inspected_by") @db.Uuid
  inspectedAt        DateTime? @map("inspected_at") @db.Timestamptz
  result             String    @default("pending")
  passedQuantity     Int       @default(0) @map("passed_quantity")
  failedQuantity     Int       @default(0) @map("failed_quantity")
  defectTypes        String[]  @map("defect_types")
  notes              String?
  photos             String[]
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  productionJob      ProductionJob @relation(fields: [productionJobId], references: [id], onDelete: Cascade)
  qcStage            QcStage       @relation(fields: [qcStageId], references: [id])
  inspector          UserProfile?  @relation("QcInspector", fields: [inspectedBy], references: [id])

  @@map("qc_records")
  @@index([productionJobId, qcStageId])
}

// =============================================
// OPERATIONS: ISSUE & ERROR TRACKING
// =============================================
model ProductionIssue {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  issueNumber        String    @unique @map("issue_number")
  orderId            String    @map("order_id") @db.Uuid
  productionJobId    String?   @map("production_job_id") @db.Uuid
  issueType          String    @map("issue_type") // defect, material_shortage, machine_error, human_error, delay
  severity           String    @default("medium") // low, medium, high, critical
  title              String
  description        String
  affectedQuantity   Int       @default(0) @map("affected_quantity")
  photos             String[]
  reportedBy         String?   @map("reported_by") @db.Uuid
  reportedAt         DateTime  @default(now()) @map("reported_at") @db.Timestamptz
  assignedTo         String?   @map("assigned_to") @db.Uuid
  status             String    @default("open") // open, investigating, resolved, closed
  resolution         String?
  resolvedBy         String?   @map("resolved_by") @db.Uuid
  resolvedAt         DateTime? @map("resolved_at") @db.Timestamptz
  costImpact         Decimal   @default(0) @map("cost_impact") @db.Decimal(10, 2)
  timeImpactHours    Int       @default(0) @map("time_impact_hours")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productionJob      ProductionJob? @relation(fields: [productionJobId], references: [id])

  @@map("production_issues")
}

// =============================================
// OPERATIONS: OUTSOURCE SYSTEM
// =============================================
model OutsourceVendor {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique
  name               String
  contactPerson      String?   @map("contact_person")
  phone              String?
  email              String?
  address            String?
  capabilities       String[]  // dtg, silkscreen, embroidery, cutting, sewing
  leadTimeDays       Int       @default(3) @map("lead_time_days")
  rating             Decimal   @default(0) @map("rating") @db.Decimal(2, 1)
  isActive           Boolean   @default(true) @map("is_active")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  outsourceJobs      OutsourceJob[]

  @@map("outsource_vendors")
}

model OutsourceJob {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobNumber          String    @unique @map("job_number")
  orderId            String    @map("order_id") @db.Uuid
  vendorId           String    @map("vendor_id") @db.Uuid
  workType           String    @map("work_type")
  description        String?
  quantity           Int       @default(0)
  unitPrice          Decimal   @default(0) @map("unit_price") @db.Decimal(10, 2)
  totalPrice         Decimal   @default(0) @map("total_price") @db.Decimal(12, 2)
  sentAt             DateTime? @map("sent_at") @db.Timestamptz
  expectedReturnAt   DateTime? @map("expected_return_at") @db.Timestamptz
  actualReturnAt     DateTime? @map("actual_return_at") @db.Timestamptz
  status             String    @default("pending") // pending, sent, in_progress, completed, returned, rejected
  receivedQuantity   Int       @default(0) @map("received_quantity")
  defectQuantity     Int       @default(0) @map("defect_quantity")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor             OutsourceVendor @relation(fields: [vendorId], references: [id])

  @@map("outsource_jobs")
}

// =============================================
// OPERATIONS: MATERIAL PROCUREMENT
// =============================================
model PurchaseRequest {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestNumber      String    @unique @map("request_number")
  orderId            String?   @map("order_id") @db.Uuid
  materialId         String?   @map("material_id") @db.Uuid
  itemName           String    @map("item_name")
  itemDescription    String?   @map("item_description")
  quantity           Decimal   @map("quantity") @db.Decimal(10, 2)
  unit               String
  estimatedPrice     Decimal   @default(0) @map("estimated_price") @db.Decimal(10, 2)
  actualPrice        Decimal   @default(0) @map("actual_price") @db.Decimal(10, 2)
  supplierId         String?   @map("supplier_id") @db.Uuid
  requestedBy        String?   @map("requested_by") @db.Uuid
  requestedAt        DateTime  @default(now()) @map("requested_at") @db.Timestamptz
  approvedBy         String?   @map("approved_by") @db.Uuid
  approvedAt         DateTime? @map("approved_at") @db.Timestamptz
  status             String    @default("pending") // pending, approved, ordered, received, cancelled
  priority           String    @default("normal") // low, normal, high, urgent
  expectedDate       DateTime? @map("expected_date") @db.Date
  receivedDate       DateTime? @map("received_date") @db.Date
  receivedQuantity   Decimal   @default(0) @map("received_quantity") @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order              Order?    @relation(fields: [orderId], references: [id])
  material           Material? @relation(fields: [materialId], references: [id])
  supplier           Supplier? @relation(fields: [supplierId], references: [id])

  @@map("purchase_requests")
}

model Supplier {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique
  name               String
  contactPerson      String?   @map("contact_person")
  phone              String?
  email              String?
  address            String?
  taxId              String?   @map("tax_id")
  paymentTerms       String?   @map("payment_terms")
  leadTimeDays       Int       @default(7) @map("lead_time_days")
  rating             Decimal   @default(0) @map("rating") @db.Decimal(2, 1)
  isActive           Boolean   @default(true) @map("is_active")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  purchaseRequests   PurchaseRequest[]

  @@map("suppliers")
}

// =============================================
// OPERATIONS: STATUS HISTORY (Reversion)
// =============================================
model StatusHistory {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType         String    @map("entity_type") // order, production_job, outsource_job
  entityId           String    @map("entity_id") @db.Uuid
  fromStatus         String    @map("from_status")
  toStatus           String    @map("to_status")
  changedBy          String?   @map("changed_by") @db.Uuid
  changedAt          DateTime  @default(now()) @map("changed_at") @db.Timestamptz
  reason             String?
  notes              String?

  @@map("status_history")
  @@index([entityType, entityId])
}

// =============================================
// FINANCE: QUOTATION SYSTEM
// =============================================
model Quotation {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationNumber    String    @unique @map("quotation_number")
  customerId         String    @map("customer_id") @db.Uuid
  title              String?
  description        String?
  subtotal           Decimal   @default(0) @map("subtotal") @db.Decimal(12, 2)
  discountPercent    Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount     Decimal   @default(0) @map("discount_amount") @db.Decimal(10, 2)
  vatPercent         Decimal   @default(7) @map("vat_percent") @db.Decimal(5, 2)
  vatAmount          Decimal   @default(0) @map("vat_amount") @db.Decimal(10, 2)
  totalAmount        Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  validUntil         DateTime? @map("valid_until") @db.Date
  status             String    @default("draft") // draft, sent, approved, rejected, expired, converted
  sentAt             DateTime? @map("sent_at") @db.Timestamptz
  approvedAt         DateTime? @map("approved_at") @db.Timestamptz
  rejectedAt         DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason    String?   @map("rejection_reason")
  convertedOrderId   String?   @map("converted_order_id") @db.Uuid
  terms              String?
  notes              String?
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  customer           Customer        @relation(fields: [customerId], references: [id])
  items              QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationId        String    @map("quotation_id") @db.Uuid
  productId          String?   @map("product_id") @db.Uuid
  description        String
  quantity           Int       @default(1)
  unitPrice          Decimal   @default(0) @map("unit_price") @db.Decimal(10, 2)
  totalPrice         Decimal   @default(0) @map("total_price") @db.Decimal(12, 2)
  notes              String?
  sortOrder          Int       @default(0) @map("sort_order")

  // Relations
  quotation          Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product            Product?  @relation(fields: [productId], references: [id])

  @@map("quotation_items")
}

// =============================================
// FINANCE: INVOICE & PAYMENT
// =============================================
model Invoice {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber      String    @unique @map("invoice_number")
  orderId            String    @map("order_id") @db.Uuid
  customerId         String    @map("customer_id") @db.Uuid
  invoiceType        String    @default("full") @map("invoice_type") // deposit, partial, full
  subtotal           Decimal   @default(0) @map("subtotal") @db.Decimal(12, 2)
  discountAmount     Decimal   @default(0) @map("discount_amount") @db.Decimal(10, 2)
  vatAmount          Decimal   @default(0) @map("vat_amount") @db.Decimal(10, 2)
  totalAmount        Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount         Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceDue         Decimal   @default(0) @map("balance_due") @db.Decimal(12, 2)
  dueDate            DateTime? @map("due_date") @db.Date
  status             String    @default("draft") // draft, sent, partial, paid, overdue, cancelled
  sentAt             DateTime? @map("sent_at") @db.Timestamptz
  paidAt             DateTime? @map("paid_at") @db.Timestamptz
  notes              String?
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order              Order     @relation(fields: [orderId], references: [id])
  customer           Customer  @relation(fields: [customerId], references: [id])
  payments           Payment[]

  @@map("invoices")
}

model Payment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentNumber      String    @unique @map("payment_number")
  invoiceId          String    @map("invoice_id") @db.Uuid
  amount             Decimal   @map("amount") @db.Decimal(12, 2)
  paymentMethod      String    @map("payment_method") // cash, transfer, credit_card, qr_code
  paymentDate        DateTime  @map("payment_date") @db.Date
  referenceNumber    String?   @map("reference_number")
  bankAccount        String?   @map("bank_account")
  proofUrl           String?   @map("proof_url")
  status             String    @default("pending") // pending, confirmed, rejected
  confirmedBy        String?   @map("confirmed_by") @db.Uuid
  confirmedAt        DateTime? @map("confirmed_at") @db.Timestamptz
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  invoice            Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// =============================================
// DELIVERY: SHIPPING & DELIVERY
// =============================================
model Shipment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentNumber     String    @unique @map("shipment_number")
  orderId            String    @map("order_id") @db.Uuid
  shippingMethod     String    @map("shipping_method") // pickup, delivery, courier
  courierName        String?   @map("courier_name")
  trackingNumber     String?   @map("tracking_number")
  shippingCost       Decimal   @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  recipientName      String    @map("recipient_name")
  recipientPhone     String    @map("recipient_phone")
  shippingAddress    String    @map("shipping_address")
  scheduledDate      DateTime? @map("scheduled_date") @db.Date
  scheduledTime      String?   @map("scheduled_time")
  shippedAt          DateTime? @map("shipped_at") @db.Timestamptz
  deliveredAt        DateTime? @map("delivered_at") @db.Timestamptz
  status             String    @default("pending") // pending, preparing, shipped, in_transit, delivered, returned
  proofOfDelivery    String?   @map("proof_of_delivery")
  receiverSignature  String?   @map("receiver_signature")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order              Order     @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

// =============================================
// COMMUNICATION: NOTIFICATIONS
// =============================================
model Notification {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String?   @map("user_id") @db.Uuid
  customerId         String?   @map("customer_id") @db.Uuid
  type               String    // order_status, payment_received, design_approved, shipment_update
  title              String
  message            String
  entityType         String?   @map("entity_type")
  entityId           String?   @map("entity_id") @db.Uuid
  channels           String[]  // app, email, line, sms
  sentChannels       String[]  @map("sent_channels")
  isRead             Boolean   @default(false) @map("is_read")
  readAt             DateTime? @map("read_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("notifications")
  @@index([userId, isRead])
  @@index([customerId, isRead])
}

